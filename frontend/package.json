{
  "name": "pvz-maze-edition",
  "version": "1.0.0",
  "description": "PVZ Maze Edition - A Plants vs Zombies maze game",
  "author": "PVZ Team",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:preview": "npm run build && electron .",
    "pack:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "phaser": "^3.70.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.35",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.pvz.maze.edition",
    "productName": "PVZ Maze Edition",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "dist/assets/**/*"
    ],
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false,
      "extraResources": [
        {
          "from": "../backend/build/Release/pvz_game.exe",
          "to": "backend/pvz_game.exe"
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns",
      "category": "public.app-category.games",
      "extraResources": [
        {
          "from": "../backend/build/pvz_game",
          "to": "backend/pvz_game"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png",
      "category": "Game",
      "extraResources": [
        {
          "from": "../backend/build/pvz_game",
          "to": "backend/pvz_game"
        }
      ]
    }
  }
}
